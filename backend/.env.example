# Copy to .env for local development:
#   cp .env.example .env

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=Haryana Roadways API
APP_VERSION=1.0.0
DEBUG=True
SECRET_KEY=haryana-roadways-super-secret-key-change-in-production-2024

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=haryana
POSTGRES_PASSWORD=haryana123
POSTGRES_DB=haryana_roadways
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ── Aadhaar (requires government API credentials for production) ─────────────
AADHAAR_ENABLED=False
AADHAAR_API_URL=
AADHAAR_API_KEY=

# ── Razorpay (leave blank for demo payment mode) ──────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_CURRENCY=INR

# ── Bus GPS (optional legacy fallback; prefer per-depot keys in admin) ───────
BUS_TRACKING_API_KEY=

# ── Dev seed admin ────────────────────────────────────────────────────────────
SEED_ADMIN_MOBILE=9999999999

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:5173

# ── File Upload ───────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=5
UPLOAD_DIR=uploads

# ── Fare Engine ───────────────────────────────────────────────────────────────
FARE_BASE_PAISE_PER_KM=85
FARE_MIN_PAISE=1000
CHILD_FARE_PERCENT=50
SENIOR_FARE_PERCENT=50
STUDENT_FARE_PERCENT=50

# ── Bus Tracking ──────────────────────────────────────────────────────────────
BUS_LOCATION_STALE_SECONDS=120
TRACKING_POLL_INTERVAL_SECONDS=15

# ── Security ──────────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
BCRYPT_ROUNDS=12
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30
