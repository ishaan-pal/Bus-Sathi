# Copy to .env for local development:
#   cp .env.example .env
#
# Values below are local-only defaults for docker-compose + dev OTP.
# Replace all secrets before deploying to production.

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=Haryana Roadways API
APP_VERSION=1.0.0
DEBUG=True
SECRET_KEY=replace-with-a-long-random-string-minimum-32-chars

# ── PostgreSQL (used by docker-compose postgres service) ────────────────────────
POSTGRES_USER=haryana
POSTGRES_PASSWORD=haryana123
POSTGRES_DB=haryana_roadways
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ── OTP (dev mode — any mobile + fixed OTP, no SMS sent) ──────────────────────
OTP_DEV_MODE=True
OTP_DEV_FIXED=123456
OTP_EXPIRE_SECONDS=300
OTP_MAX_ATTEMPTS=3

# ── SMS (https://www.fast2sms.com — required when OTP_DEV_MODE=False) ─────────
SMS_API_KEY=
SMS_SENDER_ID=HRRDWY

# ── Aadhaar (requires government API credentials) ─────────────────────────────
AADHAAR_ENABLED=False
AADHAAR_API_URL=
AADHAAR_API_KEY=

# ── Razorpay (leave blank for demo payment mode) ──────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_CURRENCY=INR

# ── Bus GPS (required when DEBUG=False) ───────────────────────────────────────
BUS_TRACKING_API_KEY=

# ── Dev seed admin — login with this mobile + OTP_DEV_FIXED ───────────────────
SEED_ADMIN_MOBILE=9999999999

# ── CORS (comma-separated) ────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:5173

# ── File Upload ───────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=5
UPLOAD_DIR=uploads

# ── Fare Engine ───────────────────────────────────────────────────────────────
FARE_BASE_PAISE_PER_KM=85
FARE_MIN_PAISE=1000
CHILD_FARE_PERCENT=50
SENIOR_FARE_PERCENT=50
STUDENT_FARE_PERCENT=50

# ── Bus Tracking ──────────────────────────────────────────────────────────────
BUS_LOCATION_STALE_SECONDS=120
TRACKING_POLL_INTERVAL_SECONDS=15

# ── Security ──────────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
BCRYPT_ROUNDS=12
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30
